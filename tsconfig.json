{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",

    "verbatimModuleSyntax": true,
    "strict": true,

    "types": ["node"],

    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,

    "skipLibCheck": true,
    "pretty": true,
    "noUncheckedIndexedAccess": true
  },
  "include": [
    "src/**/*",
    "tests/**/*",
    "scripts/**/*",
    "vitest.config.ts",
    "tsdown.config.ts"
    // "eslint.config.mjs"
  ]
}
